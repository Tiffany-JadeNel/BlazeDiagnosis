{
  "name": "blaze-pos",
  "private": true,
  "packageManager": "pnpm@10.0.0",
  "scripts": {
    "dev": "pnpm --filter @blaze-pos/web dev",
    "build": "pnpm --filter @blaze-pos/web build",
    "lint": "pnpm --filter @blaze-pos/web lint",
    "format": "pnpm --filter @blaze-pos/web format",
    "typecheck": "pnpm --filter @blaze-pos/web typecheck",
    "typegen": "pnpm --filter @blaze-pos/web typegen",
    "test:web": "pnpm --filter @blaze-pos/web exec vitest run"
  },
  "devDependencies": {
    "prettier": "latest",
    "prettier-plugin-organize-imports": "latest"
  },
  "dependencies": {
    "lucide-react": "^1.20.0",
    "zod": "^3.23.8",
    "drizzle-orm": "latest",
    "@neondatabase/serverless": "latest"
  }
}
